# 运行模式：local | testnet | live
MODE=local

# 初始虚拟资金（仅 local 模式有效）
INITIAL_BALANCE=10000

# 交易所配置（live/testnet 需要）
# Binance
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=true

# OKX
OKX_API_KEY=
OKX_API_SECRET=
OKX_PASSPHRASE=
OKX_TESTNET=true

# 通知 (QQ Bot 需要 OpenClaw 会话，这里先放空)
QQ_NOTIFY_ENABLED=false
QQ_SESSION_KEY=

# 日志级别
LOG_LEVEL=INFO
